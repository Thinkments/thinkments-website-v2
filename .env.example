# --- MACE AI Agent API Keys ---
# OpenAI API Key used by Vanguard and Execution Agents
VANGUARD_API_KEY=sk-...

# SerpApi Key used by the Global Cartographer for web search
CARTOGRAPHER_API_KEY=...

# Proxycurl Key used by Scout for LinkedIn/profile scraping
SCOUT_API_KEY=...

# --- Live Data Pipeline API Keys ---
# Coinglass API Key used by The Liquidation Node
LIQUIDATION_API_KEY=...

# WhaleAlert API Key used by The Obsidian Ledger
OBSIDIAN_API_KEY=...

# --- Google Drive Logger Configuration ---
# Target folder ID in Google Drive where agent outputs will be saved
GOOGLE_DRIVE_FOLDER_ID=...

# Stringified JSON credential blob for the Google Service Account
GOOGLE_DRIVE_CREDENTIALS={"type":"service_account","project_id":"..."}
